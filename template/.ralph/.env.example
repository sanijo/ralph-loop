# Copy this file to .ralph/.env and fill in your local values.
# .ralph/.env is gitignored because it contains secrets.

RALPH_NOTIFY=telegram
TELEGRAM_BOT_TOKEN=''
TELEGRAM_CHAT_ID=''

# Optional: notify after every successful Ralph iteration. Enabled by default.
# Set to 0 to notify only terminal states: COMPLETE, BLOCKED, ERROR, MAX_ITERATIONS.
# RALPH_NOTIFY_ON_ITERATION=1

# Optional: override the Telegram API base or request timeout.
# TELEGRAM_API_BASE=https://api.telegram.org
# RALPH_NOTIFY_TIMEOUT=10
